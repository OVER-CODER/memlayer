# MemLayer Production Environment Configuration
# Copy this to .env and fill in the values

# ============================================
# DATABASE (PostgreSQL - Supabase)
# ============================================
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql+asyncpg://postgres.abc123:your_password@db.abc123.supabase.co:6543/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.abc123:your_password@db.abc123.supabase.co:6543/postgres

# ============================================
# REDIS (Upstash)
# ============================================
# Get these from your Upstash console
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ============================================
# SECURITY
# ============================================
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-generated-secret-key-here
SECURITY_ENABLED=true

# ============================================
# LLM PROVIDERS
# ============================================
# Get API keys from respective provider dashboards
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key  # optional
ANTHROPIC_API_KEY=your-anthropic-api-key  # optional

# ============================================
# RUNTIME SETTINGS
# ============================================
DEBUG=false
LOG_LEVEL=INFO
DETERMINISTIC_MODE=true

# ============================================
# EMBEDDING (Optional - defaults work fine)
# ============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ============================================
# MEMORY SETTINGS (Optional)
# ============================================
TOP_K_MEMORIES=5
MEMORY_RETRIEVAL_THRESHOLD=0.3

# ============================================
# STORAGE (Optional - for snapshot persistence)
# ============================================
# If using S3/MinIO:
# STORAGE_PROVIDER=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT_URL=https://your-minio-endpoint

# Default is 'local' (will not persist on ephemeral filesystems)
STORAGE_PROVIDER=local