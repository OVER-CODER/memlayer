# Database
DATABASE_URL=postgresql://localhost/memlayer_dev

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Gemini API
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-pro

# Memory Configuration
TOP_K_MEMORIES=5
MEMORY_RETRIEVAL_THRESHOLD=0.3

# Server
DEBUG=true
LOG_LEVEL=INFO
