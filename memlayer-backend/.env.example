# ============================================
# MemLayer Environment Configuration
# ============================================
# Copy this to .env and configure for your environment

# ============================================
# DATABASE (Development - use PostgreSQL for production)
# ============================================
# Development (SQLite - NOT for production)
# DATABASE_URL=sqlite:///./memlayer.db

# Production (PostgreSQL - Supabase)
DATABASE_URL=postgresql+asyncpg://postgres.abc123:your_password@db.abc123.supabase.co:6543/postgres
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres.abc123:your_password@db.abc123.supabase.co:6543/postgres

# ============================================
# REDIS (Development - use Upstash for production)
# ============================================
# Development
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Production (Upstash)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ============================================
# SECURITY
# ============================================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here
SECURITY_ENABLED=true

# ============================================
# LLM PROVIDERS
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro
# OPENAI_API_KEY=your_openai_api_key  # optional
# ANTHROPIC_API_KEY=your_anthropic_api_key  # optional

# ============================================
# EMBEDDING MODEL
# ============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ============================================
# MEMORY CONFIGURATION
# ============================================
TOP_K_MEMORIES=5
MEMORY_RETRIEVAL_THRESHOLD=0.3

# ============================================
# SERVER CONFIGURATION
# ============================================
DEBUG=true
LOG_LEVEL=INFO
PORT=8000

# ============================================
# RUNTIME SETTINGS
# ============================================
DETERMINISTIC_MODE=true
